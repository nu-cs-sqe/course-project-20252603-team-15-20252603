<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
        "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
        "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<suppressions>
  <!-- Tests use BDD-style names (shouldDoX_whenY) per Catan guide §7 -->
  <suppress files="[\\/]src[\\/]test[\\/]" checks="MethodName"/>
  <!-- Expected values in assertions are intentional literals, not magic numbers -->
  <suppress files="[\\/]src[\\/]test[\\/]" checks="MagicNumber"/>
</suppressions>
